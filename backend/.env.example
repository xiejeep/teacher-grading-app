# Provider: volces | modelscope
AI_PROVIDER=volces

# Volces (豆包)
VOLCES_API_KEY=your_volces_api_key_here
VOLCES_EP_ID=ep-xxxxxxxxxxxxxxxxxxxxx

# ModelScope (魔搭)
# 注册: https://modelscope.cn 获取 SDK Token (ms-xxx 格式)
# 免费额度: 2000次/天
# 可用模型:
#   - moonshotai/Kimi-K2.6:DashScope (推荐, 支持思考模式)
#   - Qwen/Qwen3-VL-235B-A22B-Instruct
MODELSCOPE_API_KEY=ms-your-modelscope-token
MODELSCOPE_MODEL=moonshotai/Kimi-K2.6:DashScope
